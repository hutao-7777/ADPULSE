# AdPulse environment configuration
# Copy this file to .env and update values for your environment.

# ---------------------------------------------------------------------------
# Database (SQLite only)
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./adpulse.db

# ---------------------------------------------------------------------------
# Security (generate a strong SECRET_KEY in production)
# ---------------------------------------------------------------------------
SECRET_KEY=REPLACE_WITH_A_STRONG_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS whitelist (comma-separated, NO wildcard)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# Public registration
# ---------------------------------------------------------------------------
ENABLE_PUBLIC_REGISTRATION=false

# ---------------------------------------------------------------------------
# LLM provider configuration
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Agent memory
# ---------------------------------------------------------------------------
AGENT_MEMORY_TOP_K=5

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PROJECT_NAME=AdPulse
VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
