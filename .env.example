# AdPulse environment configuration
# Copy this file to .env and update values for your environment.

# ---------------------------------------------------------------------------
# Database (PostgreSQL + asyncpg)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://adpulse:adpulse@localhost:5432/adpulse
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=1800

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_MAX_CONNECTIONS=50

# ---------------------------------------------------------------------------
# Security (generate a strong SECRET_KEY in production)
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS whitelist (comma-separated, NO wildcard)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# LLM provider configuration
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Agent memory
# ---------------------------------------------------------------------------
AGENT_MEMORY_TOP_K=5

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
